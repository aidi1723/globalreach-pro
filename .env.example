# Optional server-license configuration for the desktop app.
# Leave these empty to run the open-source desktop app without activation.
GLOBALREACH_LICENSE_API_BASE_URL=
GLOBALREACH_LICENSE_PRODUCT_CODE=

# Legacy local licensing is disabled by default because the algorithm is public
# in open-source releases. Set to 1 only for private backward compatibility.
GLOBALREACH_ENABLE_LEGACY_LOCAL_LICENSE=0
